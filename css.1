/* ================================================
Quiz System — Stylesheet
বাংলা কুইজ সিস্টেম | CSS
================================================ */
 
:root{
  --bg:#0d0f1a;--card:#161927;--card2:#1e2235;
  --accent:#f7c948;--accent2:#ff6b6b;--green:#43e97b;
  --blue:#38b2f5;--purple:#a78bfa;--orange:#fb923c;
  --text:#e8eaf0;--muted:#7a7f9a;--border:#2a2f48;--radius:18px;
}
 
* {
  box-sizing:border-box;
  margin:0;
  padding:0;
}
 
body {
  background:var(--bg);
  color:var(--text);
  font-family:'Hind Siliguri',sans-serif;
  min-height:100vh;
  overflow-x:hidden;
}
 
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:radial-gradient(1px 1px at 10% 20%,rgba(247,201,72,.25)0%,transparent 100%),
radial-gradient(1px 1px at 75% 15%,rgba(56,178,245,.2)0%,transparent 100%),
radial-gradient(1px 1px at 30% 80%,rgba(167,139,250,.15)0%,transparent 100%),
radial-gradient(1px 1px at 85% 70%,rgba(67,233,123,.15)0%,transparent 100%);}
.screen {
  display:none;
  animation:fadeIn .4s ease;
}
 
.screen.active {
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  min-height:100vh;
  padding:20px;
  position:relative;
  z-index:1;
}
 
@keyframes fadeIn {
  from{opacity:0;
  transform:translateY(14px)}to{opacity:1;
  transform:translateY(0)};
}
 
/* LOGO */
.logo-area {
  text-align:center;
  margin-bottom:22px;
}
 
.logo-icon {
  font-size:48px;
  margin-bottom:6px;
  filter:drop-shadow(0 0 16px rgba(247,201,72,.4));
}
 
.logo-title {
  font-family:'Baloo Da 2',cursive;
  font-size:2.1rem;
  font-weight:800;
  background:linear-gradient(135deg,var(--accent),#ff9f43);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  line-height:1.1;
}
 
.logo-sub {
  color:var(--muted);
  font-size:.9rem;
  margin-top:4px;
}
 
/* CARD */
.card {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:26px 24px;
  width:100%;
  max-width:500px;
  box-shadow:0 8px 48px rgba(0,0,0,.5);
}
 
/* FIELD */
.field{margin-bottom:13px;}
.field label {
  display:block;
  font-size:.83rem;
  color:var(--muted);
  margin-bottom:5px;
  font-weight:500;
}
 
.field input,.field textarea,.field select {
  width:100%;
  background:var(--card2);
  border:1.5px solid var(--border);
  border-radius:11px;
  padding:10px 14px;
  color:var(--text);
  font-family:'Hind Siliguri',sans-serif;
  font-size:.93rem;
  outline:none;
  transition:border-color .2s;
}
 
.field input:focus,.field textarea:focus,.field select:focus{border-color:var(--accent);}
.field input::placeholder,.field textarea::placeholder{color:var(--muted);}
.field textarea {
  resize:vertical;
  min-height:72px;
  line-height:1.5;
}
 
.field select option{background:var(--card2);}
 
/* BUTTONS */
.btn {
  display:block;
  width:100%;
  padding:12px;
  border:none;
  border-radius:12px;
  font-family:'Baloo Da 2',cursive;
  font-size:.98rem;
  font-weight:700;
  cursor:pointer;
  transition:transform .15s,opacity .15s;
}
 
.btn:hover {
  transform:translateY(-2px);
  opacity:.92;
}
 
.btn:active{transform:translateY(0);}
.btn-primary {
  background:linear-gradient(135deg,var(--accent),#ff9f43);
  color:#1a1200;
  box-shadow:0 4px 20px rgba(247,201,72,.25);
}
 
.btn-outline {
  background:transparent;
  border:1.5px solid var(--border);
  color:var(--muted);
  font-size:.86rem;
  margin-top:9px;
}
 
.btn-outline:hover {
  border-color:var(--accent);
  color:var(--accent);
}
 
.btn-sm {
  display:inline-block;
  width:auto;
  padding:5px 13px;
  font-size:.8rem;
  border-radius:8px;
  margin-top:0;
}
 
.btn-blue {
  background:linear-gradient(135deg,var(--blue),#6c63ff);
  color:#fff;
}
 
.btn-green {
  background:linear-gradient(135deg,var(--green),#38b2f5);
  color:#0d1a10;
}
 
.btn-danger {
  background:linear-gradient(135deg,var(--accent2),#c44569);
  color:#fff;
}
 
/* HOME */
.home-btns {
  display:flex;
  flex-direction:column;
  gap:11px;
  width:100%;
  max-width:320px;
}
 
.home-btn-quiz {
  background:linear-gradient(135deg,var(--accent),#ff9f43);
  color:#1a1200;
  padding:16px;
  border:none;
  border-radius:16px;
  font-family:'Baloo Da 2',cursive;
  font-size:1.2rem;
  font-weight:800;
  cursor:pointer;
  transition:transform .15s,box-shadow .15s;
  box-shadow:0 6px 28px rgba(247,201,72,.3);
  display:flex;
  align-items:center;
  justify-content:center;
  gap:10px;
}
 
.home-btn-quiz:hover{transform:translateY(-3px);}
.home-btn-admin {
  background:var(--card);
  border:1.5px solid var(--border);
  color:var(--muted);
  padding:11px;
  border-radius:13px;
  font-family:'Baloo Da 2',cursive;
  font-size:.92rem;
  font-weight:600;
  cursor:pointer;
  transition:all .2s;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
}
 
.home-btn-admin:hover {
  border-color:var(--blue);
  color:var(--blue);
}
 
/* SELECT GRID (subject / level) */
.sel-grid {
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:9px;
  width:100%;
  max-width:500px;
  margin-bottom:18px;
}
 
.sel-card {
  background:var(--card);
  border:2px solid var(--border);
  border-radius:13px;
  padding:14px 12px;
  cursor:pointer;
  transition:all .2s;
  text-align:center;
  position:relative;
}
 
.sel-card:hover{transform:translateY(-2px);}
.sel-icon {
  font-size:1.8rem;
  margin-bottom:5px;
}
 
.sel-name {
  font-family:'Baloo Da 2',cursive;
  font-size:.95rem;
  font-weight:700;
}
 
.sel-sub {
  font-size:.74rem;
  color:var(--muted);
  margin-top:2px;
}
 
.sel-check {
  position:absolute;
  top:7px;
  right:9px;
  font-size:.85rem;
  display:none;
}
 
.sel-card.selected .sel-check{display:block;}
 
/* BIG TIMER */
.big-timer-wrap {
  text-align:center;
  margin-bottom:20px;
}
 
.big-timer-label {
  color:var(--muted);
  font-size:.8rem;
  margin-bottom:5px;
  letter-spacing:1px;
  text-transform:uppercase;
}
 
.big-timer-display {
  font-family:'Baloo Da 2',cursive;
  font-size:3.6rem;
  font-weight:800;
  background:linear-gradient(135deg,var(--accent),#ff9f43);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  letter-spacing:4px;
  line-height:1;
}
 
.big-timer-display.warn {
  background:linear-gradient(135deg,var(--accent2),#ff9f43);
  -webkit-background-clip:text;
  background-clip:text;
  animation:pulse .8s infinite;
}
 
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}
.big-timer-sub {
  color:var(--muted);
  font-size:.78rem;
  margin-top:4px;
}
 
/* INFO ROW (subject + level + marks) */
.info-row {
  display:flex;
  gap:7px;
  flex-wrap:wrap;
  margin-bottom:14px;
}
 
.info-pill {
  padding:4px 11px;
  border-radius:20px;
  font-size:.74rem;
  font-weight:600;
  border:1px solid;
}
 
/* QUIZ */
.quiz-header {
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  margin-bottom:12px;
}
 
.quiz-meta {
  display:flex;
  flex-direction:column;
  gap:4px;
}
 
.quiz-name {
  font-weight:600;
  color:var(--accent);
  font-size:.88rem;
}
 
.timer-badge {
  display:flex;
  align-items:center;
  gap:5px;
  background:var(--card2);
  border:1.5px solid var(--border);
  border-radius:10px;
  padding:5px 11px;
  font-family:'Baloo Da 2',cursive;
  font-weight:700;
  font-size:.95rem;
  letter-spacing:1px;
  transition:all .3s;
  white-space:nowrap;
}
 
.timer-badge.warn {
  border-color:var(--accent2);
  color:var(--accent2);
  background:rgba(255,107,107,.08);
  animation:pulse .8s infinite;
}
 
.progress-bar-wrap {
  background:var(--card2);
  border-radius:7px;
  height:5px;
  margin-bottom:16px;
  overflow:hidden;
}
 
.progress-bar-fill {
  height:100%;
  background:linear-gradient(90deg,var(--accent),#ff9f43);
  border-radius:7px;
  transition:width .4s;
}
 
/* QUESTION HEADER */
.q-header-row {
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:4px;
}
 
.question-num {
  color:var(--muted);
  font-size:.8rem;
}
 
.mark-badge {
  background:rgba(247,201,72,.12);
  border:1px solid rgba(247,201,72,.3);
  color:var(--accent);
  font-size:.75rem;
  font-weight:700;
  padding:2px 9px;
  border-radius:20px;
}
 
.question-text {
  font-family:'Baloo Da 2',cursive;
  font-size:1.1rem;
  font-weight:700;
  margin-bottom:15px;
  line-height:1.55;
  color:var(--text);
  white-space:pre-line;
}
 
.options {
  display:flex;
  flex-direction:column;
  gap:8px;
}
 
.option-btn {
  background:var(--card2);
  border:1.5px solid var(--border);
  border-radius:11px;
  padding:11px 14px;
  color:var(--text);
  font-family:'Hind Siliguri',sans-serif;
  font-size:.93rem;
  text-align:left;
  cursor:pointer;
  transition:all .2s;
  display:flex;
  align-items:center;
  gap:9px;
}
 
.option-btn:hover:not(:disabled) {
  border-color:var(--accent);
  background:rgba(247,201,72,.07);
}
 
.option-btn.selected-opt {
  border-color:var(--accent);
  background:rgba(247,201,72,.09);
}
 
.option-btn:disabled{cursor:default;}
.option-letter {
  width:25px;
  height:25px;
  border-radius:50%;
  background:var(--border);
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:700;
  font-size:.8rem;
  flex-shrink:0;
}
 
.next-btn-wrap{margin-top:15px;}
.context-box {
  background:rgba(56,178,245,.08);
  border:1px solid rgba(56,178,245,.25);
  border-radius:9px;
  padding:9px 13px;
  margin-bottom:11px;
  font-size:.88rem;
  color:var(--blue);
  line-height:1.6;
}
 
/* RESULT */
.result-wrap {
  width:100%;
  max-width:620px;
  padding-bottom:40px;
}
 
.result-top {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:22px;
  text-align:center;
  margin-bottom:12px;
}
 
.result-icon {
  font-size:60px;
  margin-bottom:8px;
}
 
.result-score-big {
  font-family:'Baloo Da 2',cursive;
  font-size:2.6rem;
  font-weight:800;
  background:linear-gradient(135deg,var(--accent),#ff9f43);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}
 
.result-label {
  color:var(--muted);
  font-size:.85rem;
  margin-bottom:2px;
}
 
.result-marks-row {
  display:flex;
  gap:12px;
  justify-content:center;
  margin:10px 0 6px;
  flex-wrap:wrap;
}
 
.result-mark-box {
  background:var(--card2);
  border:1px solid var(--border);
  border-radius:11px;
  padding:10px 18px;
  text-align:center;
  min-width:90px;
}
 
.rmb-val {
  font-family:'Baloo Da 2',cursive;
  font-size:1.4rem;
  font-weight:800;
}
 
.rmb-lbl {
  font-size:.72rem;
  color:var(--muted);
  margin-top:2px;
}
 
.result-time {
  color:var(--blue);
  font-size:.85rem;
  margin-bottom:4px;
}
 
.result-msg {
  font-size:.97rem;
  color:var(--text);
  margin:8px 0 18px;
  font-weight:500;
}
 
/* REVIEW */
.review-box {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:16px;
}
 
.review-title {
  font-family:'Baloo Da 2',cursive;
  font-size:1rem;
  font-weight:700;
  color:var(--accent);
  margin-bottom:12px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}
 
.review-summary {
  font-size:.78rem;
  color:var(--muted);
}
 
.review-item {
  background:var(--card2);
  border-radius:12px;
  padding:12px 14px;
  margin-bottom:9px;
  border:1.5px solid var(--border);
}
 
.review-item.ri-correct{border-color:rgba(67,233,123,.3);}
.review-item.ri-wrong{border-color:rgba(255,107,107,.3);}
.review-item.ri-skip{border-color:var(--border);}
.review-q-num {
  font-size:.73rem;
  color:var(--muted);
  margin-bottom:3px;
  display:flex;
  justify-content:space-between;
}
 
.review-q-mark {
  font-size:.73rem;
  font-weight:700;
}
 
.review-q-text {
  font-family:'Baloo Da 2',cursive;
  font-size:.94rem;
  font-weight:700;
  margin-bottom:8px;
  white-space:pre-line;
  line-height:1.4;
}
 
.review-opts {
  display:flex;
  flex-direction:column;
  gap:4px;
}
 
.review-opt {
  display:flex;
  align-items:center;
  gap:7px;
  padding:6px 10px;
  border-radius:8px;
  font-size:.85rem;
  border:1.5px solid var(--border);
}
 
.review-opt.r-correct {
  border-color:var(--green);
  background:rgba(67,233,123,.1);
  color:var(--green);
}
 
.review-opt.r-wrong {
  border-color:var(--accent2);
  background:rgba(255,107,107,.1);
  color:var(--accent2);
}
 
.r-letter {
  width:21px;
  height:21px;
  border-radius:50%;
  background:var(--border);
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:700;
  font-size:.72rem;
  flex-shrink:0;
}
 
.r-correct .r-letter {
  background:var(--green);
  color:#0d1a10;
}
 
.r-wrong .r-letter {
  background:var(--accent2);
  color:#fff;
}
 
/* ADMIN */
.admin-wrap {
  width:100%;
  max-width:860px;
}
 
.admin-topbar {
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:13px;
}
 
.admin-title {
  font-family:'Baloo Da 2',cursive;
  font-size:1.35rem;
  font-weight:800;
  color:var(--blue);
}
 
.tab-bar {
  display:flex;
  gap:5px;
  margin-bottom:16px;
  background:var(--card);
  border:1px solid var(--border);
  border-radius:12px;
  padding:5px;
}
 
.tab-btn {
  flex:1;
  padding:8px 5px;
  border:none;
  border-radius:8px;
  font-family:'Baloo Da 2',cursive;
  font-size:.84rem;
  font-weight:700;
  cursor:pointer;
  background:transparent;
  color:var(--muted);
  transition:all .2s;
}
 
.tab-btn.active {
  background:var(--card2);
  color:var(--accent);
}
 
.tab-content{display:none;}
.tab-content.active{display:block;}
.stats-row {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:9px;
  margin-bottom:16px;
}
 
.stat-card {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:12px;
  padding:13px;
  text-align:center;
}
 
.stat-num {
  font-family:'Baloo Da 2',cursive;
  font-size:1.7rem;
  font-weight:800;
  color:var(--accent);
}
 
.stat-lbl {
  color:var(--muted);
  font-size:.76rem;
  margin-top:2px;
}
 
/* TABLE */
.tbl-wrap {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
}
 
.tbl-head {
  display:grid;
  grid-template-columns:36px 1fr 90px 80px 110px 82px;
  padding:10px 15px;
  background:var(--card2);
  border-bottom:1px solid var(--border);
  font-size:.73rem;
  color:var(--muted);
  font-weight:600;
  text-transform:uppercase;
  letter-spacing:.3px;
}
 
.tbl-row {
  display:grid;
  grid-template-columns:36px 1fr 90px 80px 110px 82px;
  padding:10px 15px;
  border-bottom:1px solid var(--border);
  align-items:center;
  font-size:.87rem;
}
 
.tbl-row:last-child{border-bottom:none;}
.tbl-row:hover{background:rgba(247,201,72,.03);}
.rank {
  color:var(--muted);
  font-weight:600;
  font-size:.82rem;
}
 
.rank.top1 {
  color:var(--accent);
  font-size:.96rem;
}
 
.rank.top2{color:#bdc3d4;}
.rank.top3{color:#cd7f32;}
.p-name {
  font-weight:600;
  font-size:.88rem;
}
 
.score-badge {
  display:inline-block;
  padding:3px 8px;
  border-radius:20px;
  font-weight:700;
  font-size:.77rem;
}
 
.score-high {
  background:rgba(67,233,123,.15);
  color:var(--green);
}
 
.score-mid {
  background:rgba(247,201,72,.15);
  color:var(--accent);
}
 
.score-low {
  background:rgba(255,107,107,.15);
  color:var(--accent2);
}
 
.time-col {
  color:var(--blue);
  font-size:.8rem;
  text-align:right;
}
 
.lvl-chip {
  font-size:.72rem;
  color:var(--purple);
  background:rgba(167,139,250,.1);
  border:1px solid rgba(167,139,250,.3);
  padding:2px 7px;
  border-radius:20px;
}
 
/* SUBJECT MANAGER */
.subj-list {
  display:flex;
  flex-direction:column;
  gap:8px;
  margin-bottom:12px;
}
 
.subj-item {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:12px;
  padding:12px 15px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}
 
.subj-item-left {
  display:flex;
  align-items:center;
  gap:9px;
}
 
.subj-emoji{font-size:1.4rem;}
.subj-item-name {
  font-family:'Baloo Da 2',cursive;
  font-weight:700;
  font-size:.96rem;
}
 
.subj-item-count {
  font-size:.75rem;
  color:var(--muted);
}
 
.subj-item-actions {
  display:flex;
  gap:5px;
}
 
/* LEVEL MANAGER */
.lvl-list {
  display:flex;
  flex-direction:column;
  gap:8px;
  margin-bottom:12px;
}
 
.lvl-item {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:12px;
  padding:12px 15px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}
 
.lvl-item-left {
  display:flex;
  align-items:center;
  gap:9px;
}
 
.lvl-badge-big {
  font-family:'Baloo Da 2',cursive;
  font-size:1rem;
  font-weight:700;
  padding:4px 12px;
  border-radius:20px;
  background:rgba(167,139,250,.12);
  color:var(--purple);
  border:1px solid rgba(167,139,250,.3);
}
 
.lvl-item-count {
  font-size:.75rem;
  color:var(--muted);
  margin-top:2px;
}
 
.lvl-item-actions {
  display:flex;
  gap:5px;
}
 
/* Q MANAGER */
.q-filter-bar {
  display:flex;
  gap:7px;
  align-items:center;
  margin-bottom:11px;
  flex-wrap:wrap;
}
 
.q-filter-bar select {
  background:var(--card2);
  border:1.5px solid var(--border);
  border-radius:9px;
  padding:7px 11px;
  color:var(--text);
  font-family:'Hind Siliguri',sans-serif;
  font-size:.85rem;
  outline:none;
}
 
.q-count-badge {
  background:var(--card2);
  border:1px solid var(--border);
  border-radius:7px;
  padding:3px 10px;
  font-size:.8rem;
  color:var(--muted);
}
 
.q-list {
  display:flex;
  flex-direction:column;
  gap:8px;
  max-height:430px;
  overflow-y:auto;
  padding-right:3px;
}
 
.q-list::-webkit-scrollbar{width:3px;}
.q-list::-webkit-scrollbar-thumb {
  background:var(--border);
  border-radius:3px;
}
 
.q-item {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:12px;
  padding:12px 14px;
}
 
.q-item-top {
