  white-space:pre-line;
}
 
.q-item-meta {
  display:flex;
  flex-direction:column;
  align-items:flex-end;
  gap:3px;
  flex-shrink:0;
}
 
.q-item-num {
  font-size:.72rem;
  color:var(--muted);
}
 
.q-item-opts {
  display:flex;
  flex-wrap:wrap;
  gap:4px;
  margin-top:7px;
}
 
.q-opt-chip {
  padding:2px 8px;
  border-radius:6px;
  font-size:.74rem;
  background:var(--card2);
  border:1px solid var(--border);
  color:var(--muted);
}
 
.q-opt-chip.correct-chip {
  border-color:var(--green);
  color:var(--green);
  background:rgba(67,233,123,.08);
}
 
.q-item-actions {
  display:flex;
  gap:5px;
  margin-top:8px;
}
 
.mark-chip {
  background:rgba(247,201,72,.1);
  border:1px solid rgba(247,201,72,.3);
  color:var(--accent);
  font-size:.72rem;
  font-weight:700;
  padding:2px 8px;
  border-radius:20px;
}
 
/* MODAL */
.modal-overlay {
  display:none;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.78);
  z-index:100;
  align-items:center;
  justify-content:center;
  padding:14px;
}
 
.modal-overlay.open{display:flex;}
.modal {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:22px;
  width:100%;
  max-width:560px;
  max-height:92vh;
  overflow-y:auto;
  box-shadow:0 16px 64px rgba(0,0,0,.6);
}
 
.modal-sm{max-width:400px;}
.modal-title {
  font-family:'Baloo Da 2',cursive;
  font-size:1.15rem;
  font-weight:700;
  color:var(--accent);
  margin-bottom:14px;
}
 
.opt-row {
  display:flex;
  align-items:center;
  gap:7px;
  margin-bottom:8px;
}
 
.opt-letter-badge {
  width:24px;
  height:24px;
  border-radius:50%;
  background:var(--border);
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:700;
  font-size:.77rem;
  flex-shrink:0;
}
 
.opt-row input {
  flex:1;
  background:var(--card2);
  border:1.5px solid var(--border);
  border-radius:9px;
  padding:8px 12px;
  color:var(--text);
  font-family:'Hind Siliguri',sans-serif;
  font-size:.9rem;
  outline:none;
  transition:border-color .2s;
}
 
.opt-row input:focus{border-color:var(--accent);}
.correct-radio {
  appearance:none;
  width:17px;
  height:17px;
  border-radius:50%;
  border:2px solid var(--border);
  flex-shrink:0;
  cursor:pointer;
  transition:all .2s;
}
 
.correct-radio:checked {
  border-color:var(--green);
  background:var(--green);
}
 
.modal-hint {
  font-size:.76rem;
  color:var(--muted);
  margin-bottom:8px;
}
 
.modal-actions {
  display:flex;
  gap:9px;
  margin-top:16px;
}
 
.modal-actions .btn {
  flex:1;
  margin-top:0;
}
 
.error-msg {
  color:var(--accent2);
  font-size:.83rem;
  text-align:center;
  margin-top:7px;
  min-height:17px;
}
 
.emoji-grid {
  display:flex;
  flex-wrap:wrap;
  gap:7px;
  margin-bottom:12px;
}
 
.emoji-opt {
  font-size:1.5rem;
  padding:5px 9px;
  border-radius:8px;
  cursor:pointer;
  border:2px solid transparent;
  transition:all .2s;
}
 
.emoji-opt:hover,.emoji-opt.active {
  border-color:var(--accent);
  background:rgba(247,201,72,.1);
}
 
/* ── SCIENCE HOME ── */
#screen-home {
  overflow:hidden;
  position:relative;
}
 
/* ── PAGE TEMPLATE (subject / level / join) ── */
.page-bg-sci {
  position:fixed;
  inset:0;
  pointer-events:none;
  z-index:0;
  overflow:hidden;
}
 
.pg-sym {
  position:absolute;
  font-size:2.2rem;
  opacity:.06;
  animation:floatSym 7s ease-in-out infinite;
}
 
.ps1 {
  top:6%;
  left:6%;
  animation-delay:0s;
}
 
.ps2 {
  top:10%;
  right:8%;
  animation-delay:1s;
}
 
.ps3 {
  bottom:18%;
  left:5%;
  animation-delay:2s;
}
 
.ps4 {
  bottom:10%;
  right:6%;
  animation-delay:1.5s;
}
 
.ps5 {
  top:42%;
  left:3%;
  font-size:2.8rem;
  font-family:monospace;
  animation-delay:.6s;
}
 
.ps6 {
  top:55%;
  right:4%;
  font-size:2.8rem;
  font-family:monospace;
  animation-delay:2.4s;
}
 
.page-inner {
  position:relative;
  z-index:1;
  display:flex;
  flex-direction:column;
  align-items:center;
  width:100%;
  max-width:520px;
  gap:0;
}
 
.page-header {
  text-align:center;
  margin-bottom:20px;
}
 
.page-step-badge {
  display:inline-block;
  background:rgba(56,178,245,.1);
  border:1px solid rgba(56,178,245,.3);
  color:var(--blue);
  font-size:.72rem;
  font-weight:700;
  padding:4px 14px;
  border-radius:20px;
  margin-bottom:10px;
  letter-spacing:.8px;
}
 
.page-title {
  font-family:'Baloo Da 2',cursive;
  font-size:1.9rem;
  font-weight:800;
  color:var(--text);
  line-height:1.1;
  margin-bottom:5px;
}
 
.page-sub {
  color:var(--muted);
  font-size:.88rem;
}
 
/* ── JOIN TIMER BOX ── */
.join-timer-box {
  background:linear-gradient(135deg,rgba(247,201,72,.08),rgba(255,159,67,.05));
  border:1.5px solid rgba(247,201,72,.3);
  border-radius:18px;
  padding:18px 28px;
  text-align:center;
  margin-bottom:18px;
  width:100%;
  max-width:440px;
  position:relative;
  overflow:hidden;
}
 
.join-timer-box::before {
  content:'';
  position:absolute;
  inset:0;
  background:radial-gradient(circle at 50% 0%,rgba(247,201,72,.07),transparent 70%);
  pointer-events:none;
}
 
.jtb-label {
  font-size:.76rem;
  color:var(--muted);
  letter-spacing:1px;
  text-transform:uppercase;
  margin-bottom:6px;
}
 
.jtb-time {
  font-family:'Baloo Da 2',cursive;
  font-size:3.2rem;
  font-weight:800;
  background:linear-gradient(135deg,var(--accent),#ff9f43);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  letter-spacing:4px;
  line-height:1;
}
 
.jtb-note {
  font-size:.75rem;
  color:var(--muted);
  margin-top:6px;
}
 
/* start button variant */
.btn-start-quiz {
  background:linear-gradient(135deg,#0e1f15,#0a1525);
  border:1.5px solid rgba(67,233,123,.5);
  color:var(--green);
  font-size:1.05rem;
  box-shadow:0 4px 20px rgba(67,233,123,.15);
}
 
.btn-start-quiz:hover {
  border-color:rgba(67,233,123,.85);
  box-shadow:0 6px 28px rgba(67,233,123,.25);
}
 
/* ── QUIZ SCREEN ── */
#screen-quiz {
  flex-direction:row;
  align-items:stretch;
  justify-content:center;
  gap:0;
  padding:16px 8px;
  min-height:100vh;
}
 
/* Side panels */
.quiz-side-left,.quiz-side-right {
  width:160px;
  flex-shrink:0;
  display:flex;
  flex-direction:column;
  align-items:flex-start;
  justify-content:center;
  gap:14px;
  padding:20px 10px;
  opacity:.55;
  pointer-events:none;
}
 
.quiz-side-right{align-items:flex-end;}
 
/* mini atom on left side */
.qsl-atom {
  position:relative;
  width:60px;
  height:60px;
  margin-bottom:4px;
}
 
.qsl-nucleus {
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
  width:10px;
  height:10px;
  border-radius:50%;
  background:var(--blue);
  box-shadow:0 0 8px var(--blue);
  animation:nucPulse 2s ease-in-out infinite;
}
 
.qsl-orbit {
  position:absolute;
  inset:0;
  border-radius:50%;
  border:1px solid rgba(56,178,245,.4);
}
 
.qo1{animation:spin1 4s linear infinite;}
.qo2 {
  transform:rotateX(65deg);
  animation:spin2 6s linear infinite;
}
 
.qsl-e {
  position:absolute;
  top:-4px;
  left:50%;
  width:7px;
  height:7px;
  border-radius:50%;
  background:var(--blue);
  transform:translateX(-50%);
}
 
.qse2{background:var(--green);}
 
/* formula labels */
.qsl-formula {
  font-family:monospace;
  font-size:.72rem;
  color:rgba(56,178,245,.5);
  white-space:nowrap;
  animation:floatSym 6s ease-in-out infinite;
}
 
.qsl-formula:nth-child(2){animation-delay:.5s;}
.qsl-formula:nth-child(3){animation-delay:1.2s;}
.qsl-formula:nth-child(4){animation-delay:2s;}
 
/* dot decorations */
.qsl-dots {
  display:flex;
  gap:6px;
  margin-top:8px;
}
 
.qsd {
  width:8px;
  height:8px;
  border-radius:50%;
  background:rgba(56,178,245,.3);
  animation:nucPulse 2s ease-in-out infinite;
}
 
.qsd:nth-child(2) {
  animation-delay:.4s;
  background:rgba(67,233,123,.3);
}
 
.qsd:nth-child(3) {
  animation-delay:.8s;
  background:rgba(247,201,72,.3);
}
 
.qsd-purple{background:rgba(167,139,250,.4)!important;}
.qsd-green{background:rgba(67,233,123,.4)!important;}
 
/* Beaker decoration */
.qsr-beaker {
  display:flex;
  flex-direction:column;
  align-items:center;
  margin-bottom:6px;
}
 
.qsr-bk-top {
  width:28px;
  height:4px;
  background:rgba(56,178,245,.4);
  border-radius:3px;
}
 
.qsr-bk-neck {
  width:18px;
  height:14px;
  background:rgba(56,178,245,.15);
  border:1px solid rgba(56,178,245,.3);
}
 
.qsr-bk-body {
  width:44px;
  height:48px;
  background:rgba(56,178,245,.08);
  border:1px solid rgba(56,178,245,.3);
  border-radius:0 0 12px 12px;
  position:relative;
  overflow:hidden;
}
 
.qsr-bk-liquid {
  position:absolute;
  bottom:0;
  left:0;
  right:0;
  height:55%;
  background:rgba(67,233,123,.2);
  border-radius:0 0 10px 10px;
  animation:liquidWave 3s ease-in-out infinite;
}
 
@keyframes liquidWave{0%,100%{height:55%}50%{height:62%}}
.qsr-bubble {
  position:absolute;
  border-radius:50%;
  background:rgba(67,233,123,.4);
  animation:bubbleRise 3s ease-in-out infinite;
}
 
.b1 {
  width:5px;
  height:5px;
  left:25%;
  bottom:5%;
  animation-delay:0s;
}
 
.b2 {
  width:4px;
  height:4px;
  left:55%;
  bottom:15%;
  animation-delay:1s;
}
 
.b3 {
  width:6px;
  height:6px;
  left:40%;
  bottom:10%;
  animation-delay:2s;
}
 
@keyframes bubbleRise {
  0%{transform:translateY(0);
  opacity:.8}100%{transform:translateY(-40px);
  opacity:0};
}
 
/* Quiz card */
.quiz-card-wrap {
  flex:1;
  max-width:560px;
  display:flex;
  flex-direction:column;
  gap:0;
  background:var(--card);
  border:1px solid var(--border);
  border-radius:22px;
  padding:22px 24px;
  box-shadow:0 8px 48px rgba(0,0,0,.5);
  position:relative;
  overflow:hidden;
}
 
.quiz-card-wrap::before {
  content:'';
  position:absolute;
  top:0;
  left:0;
  right:0;
  height:3px;
  background:linear-gradient(90deg,var(--blue),var(--green),var(--accent),var(--accent2));
  border-radius:22px 22px 0 0;
}
 
.quiz-topbar {
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  margin-bottom:14px;
}
 
.quiz-progress-section{margin-bottom:4px;}
 
/* Question box */
.question-box {
  background:linear-gradient(135deg,rgba(56,178,245,.05),rgba(167,139,250,.04));
  border:1px solid rgba(56,178,245,.15);
  border-radius:16px;
  padding:18px 18px 14px;
  margin-bottom:16px;
  position:relative;
}
 
.question-box-inner{position:relative;}
.question-deco-top {
  position:absolute;
  top:-10px;
  right:10px;
  width:28px;
  height:28px;
  border-radius:50%;
  background:linear-gradient(135deg,var(--blue),var(--purple));
  display:flex;
  align-items:center;
  justify-content:center;
  font-family:'Baloo Da 2',cursive;
  font-size:1rem;
  font-weight:800;
  color:white;
  box-shadow:0 2px 10px rgba(56,178,245,.4);
}
 
.question-text {
  font-family:'Baloo Da 2',cursive;
  font-size:1.12rem;
  font-weight:700;
  margin-bottom:0;
  line-height:1.55;
  color:var(--text);
  white-space:pre-line;
  padding-right:30px;
}
 
/* Options redesign */
.options {
  display:flex;
  flex-direction:column;
  gap:9px;
}
 
.option-btn {
  background:var(--card2);
  border:1.5px solid var(--border);
  border-radius:13px;
  padding:13px 16px;
  color:var(--text);
  font-family:'Hind Siliguri',sans-serif;
  font-size:.95rem;
  text-align:left;
  cursor:pointer;
  transition:all .22s;
  display:flex;
  align-items:center;
  gap:11px;
  position:relative;
  overflow:hidden;
}
 
.option-btn::before {
  content:'';
  position:absolute;
  inset:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.015));
  pointer-events:none;
}
 
.option-btn:hover:not(:disabled) {
  border-color:var(--accent);
  background:rgba(247,201,72,.07);
  transform:translateX(4px);
}
 
.option-btn.selected-opt {
  border-color:var(--accent);
  background:rgba(247,201,72,.09);
  transform:translateX(4px);
}
 
.option-btn:disabled{cursor:default;}
.option-letter {
  width:28px;
  height:28px;
  border-radius:8px;
  background:var(--border);
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:800;
  font-size:.82rem;
  flex-shrink:0;
  transition:all .2s;
  font-family:'Baloo Da 2',cursive;
}
 
.option-btn:hover:not(:disabled) .option-letter {
  background:var(--accent);
  color:#1a1200;
}
 
.option-btn.selected-opt .option-letter {
  background:var(--accent);
  color:#1a1200;
}
 
.option-btn.correct {
  border-color:var(--green);
  background:rgba(67,233,123,.1);
  color:var(--green);
}
 
.option-btn.correct .option-letter {
  background:var(--green);
  color:#0d1a10;
}
 
.option-btn.wrong {
  border-color:var(--accent2);
  background:rgba(255,107,107,.1);
  color:var(--accent2);
}
 
.option-btn.wrong .option-letter {
  background:var(--accent2);
  color:#fff;
}
 
@media(max-width:860px){
.quiz-side-left,.quiz-side-right{display:none;}
#screen-quiz{padding:14px;}
.quiz-card-wrap {
  border-radius:18px;
  padding:18px 16px;
}
 
}
 
@media(max-width:440px){
.quiz-card-wrap{padding:14px 13px;}
}
 
/* ── PAGE TEMPLATE (subject / level / join) ── */
.sel-bg {
  position:fixed;
  inset:0;
  pointer-events:none;
  z-index:0;
  overflow:hidden;
}
 
.sel-svg {
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
}
 
.sel-fsym {
  position:absolute;
  font-size:2rem;
  opacity:.07;
  animation:floatSym 8s ease-in-out infinite;
  pointer-events:none;
  user-select:none;
}
 
.sf1 {
  top:5%;
  left:4%;
  animation-delay:0s;
}
 
.sf2 {
  top:8%;
  right:5%;
  animation-delay:1.2s;
}
 
.sf3 {
  bottom:15%;
  left:3%;
  animation-delay:2s;
}
 
.sf4 {
  bottom:8%;
  right:4%;
  animation-delay:1.6s;
}
 
.sf5 {
  top:40%;
  left:2%;
  font-size:2.4rem;
  font-family:monospace;
  animation-delay:.6s;
  opacity:.06;
}
 
.sf6 {
  top:55%;
  right:2%;
  font-size:2.4rem;
  font-family:monospace;
  animation-delay:2.4s;
  opacity:.06;
}
 
.sf7 {
  top:25%;
  left:45%;
  font-size:1.6rem;
  font-family:monospace;
  animation-delay:3s;
  opacity:.05;
}
 
.sf8 {
  bottom:35%;
  right:38%;
  font-size:1.6rem;
  font-family:monospace;
  animation-delay:1s;
  opacity:.05;
}
 
.sel-page-wrap {
  position:relative;
  z-index:1;
  display:flex;
  flex-direction:column;
  align-items:center;
  width:100%;
  max-width:560px;
  padding:0 16px;
}
 
/* STEP TRACKER */
.step-track {
  display:flex;
  align-items:center;
  gap:0;
  margin-bottom:22px;
}
 
.step-item {
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:4px;
}
 
.step-dot {
  width:34px;
  height:34px;
  border-radius:50%;
  background:var(--card2);
  border:2px solid var(--border);
  color:var(--muted);
  font-family:'Baloo Da 2',cursive;
  font-weight:700;
  font-size:.88rem;
  display:flex;
  align-items:center;
  justify-content:center;
  transition:all .3s;
}
 
.step-lbl {
  font-size:.65rem;
  color:var(--muted);
  font-weight:500;
  white-space:nowrap;
}
 
.step-line {
  width:48px;
  height:2px;
  background:var(--border);
  margin:0 4px;
  margin-bottom:18px;
  transition:background .3s;
}
 
.step-line-done{background:linear-gradient(90deg,var(--green),var(--blue));}
.step-active .step-dot {
  background:linear-gradient(135deg,var(--blue),var(--purple));
  border-color:transparent;
  color:#fff;
  box-shadow:0 0 14px rgba(56,178,245,.4);
}
 
.step-active .step-lbl {
  color:var(--blue);
  font-weight:700;
}
 
.step-done .step-dot {
  background:linear-gradient(135deg,var(--green),var(--blue));
  border-color:transparent;
  color:#0d1a10;
}
 
.step-done .step-lbl{color:var(--green);}
 
/* SEL HEADER */
.sel-header {
  text-align:center;
  margin-bottom:20px;
}
 
.sel-title-icon {
  font-size:2.6rem;
  margin-bottom:7px;
  filter:drop-shadow(0 0 14px rgba(247,201,72,.3));
}
 
.sel-title {
  font-family:'Baloo Da 2',cursive;
  font-size:2rem;
  font-weight:800;
  background:linear-gradient(135deg,var(--text),rgba(255,255,255,.7));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  margin-bottom:4px;
}
 
.sel-sub {
  color:var(--muted);
  font-size:.9rem;
}
 
/* SEL GRID */
.sel-grid {
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:12px;
  width:100%;
  max-width:520px;
  margin-bottom:18px;
}
 
.sel-card {
  background:var(--card);
  border:2px solid var(--border);
  border-radius:16px;
  padding:18px 14px;
  cursor:pointer;
  transition:all .25s;
  text-align:center;
  position:relative;
  overflow:hidden;
}
 
.sel-card::after {
  content:'';
  position:absolute;
  inset:0;
  background:linear-gradient(135deg,transparent 60%,rgba(255,255,255,.02));
  pointer-events:none;
}
 
.sel-card:hover {
  transform:translateY(-4px);
  box-shadow:0 10px 30px rgba(0,0,0,.35);
}
 
.sel-icon {
  font-size:2.4rem;
  margin-bottom:8px;
  transition:transform .22s;
  display:block;
}
 
.sel-card:hover .sel-icon{transform:scale(1.18) rotate(-4deg);}
.sel-name {
  font-family:'Baloo Da 2',cursive;
  font-size:1.05rem;
  font-weight:700;
}
 
.sel-sub-txt {
  font-size:.75rem;
  color:var(--muted);
  margin-top:4px;
}
 
.sel-check {
  position:absolute;
  top:9px;
  right:11px;
  font-size:.88rem;
  display:none;
}
 
.sel-card.selected .sel-check{display:block;}
 
/* SEL BUTTONS */
.sel-btns {
  display:flex;
  flex-direction:column;
  gap:8px;
  width:100%;
  max-width:520px;
}
 
.btn-sel-next {
