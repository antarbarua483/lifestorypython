.toast.wrong-t {
  border-color:var(--accent2);
  color:var(--accent2);
}
 
.toast.info-t {
  border-color:var(--blue);
  color:var(--blue);
}
 
.empty-state {
  padding:34px;
  text-align:center;
  color:var(--muted);
}
 
.empty-icon {
  font-size:38px;
  margin-bottom:7px;
}
 
/* ── NEW FEATURES CSS ── */
/* Settings Tab */
.settings-grid {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
  margin-bottom:16px;
}
 
@media(max-width:560px){.settings-grid{grid-template-columns:1fr;}}
.settings-card {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:14px;
  padding:16px;
}
 
.settings-card-title {
  font-family:'Baloo Da 2',cursive;
  font-size:.92rem;
  font-weight:700;
  color:var(--blue);
  margin-bottom:12px;
  display:flex;
  align-items:center;
  gap:6px;
}
 
.settings-input-row {
  display:flex;
  gap:8px;
  align-items:flex-end;
}
 
.settings-input-row .field {
  flex:1;
  margin-bottom:0;
}
 
.settings-input-row button{flex-shrink:0;}
 
/* Import */
.import-drop {
  border:2px dashed var(--border);
  border-radius:12px;
  padding:22px;
  text-align:center;
  cursor:pointer;
  transition:all .2s;
  background:var(--card2);
}
 
.import-drop:hover,.import-drop.dragover {
  border-color:var(--accent);
  background:rgba(247,201,72,.06);
}
 
.import-drop-icon {
  font-size:2rem;
  margin-bottom:6px;
}
 
.import-drop-text {
  font-size:.85rem;
  color:var(--muted);
}
 
.import-preview {
  background:var(--card2);
  border:1px solid var(--border);
  border-radius:10px;
  padding:12px;
  margin-top:10px;
  font-size:.8rem;
  max-height:140px;
  overflow-y:auto;
}
 
.import-preview pre {
  color:var(--text);
  white-space:pre-wrap;
  word-break:break-all;
}
 
.import-result {
  margin-top:8px;
  font-size:.83rem;
  font-weight:600;
}
 
.import-result.ok{color:var(--green);}
.import-result.err{color:var(--accent2);}
 
/* Tag chips */
.tag-input-wrap {
  display:flex;
  flex-wrap:wrap;
  gap:5px;
  background:var(--card2);
  border:1.5px solid var(--border);
  border-radius:11px;
  padding:6px 10px;
  min-height:40px;
  align-items:center;
  cursor:text;
}
 
.tag-input-wrap:focus-within{border-color:var(--accent);}
.tag-chip {
  display:flex;
  align-items:center;
  gap:3px;
  background:rgba(167,139,250,.15);
  border:1px solid rgba(167,139,250,.35);
  color:var(--purple);
  border-radius:20px;
  padding:2px 8px;
  font-size:.78rem;
  white-space:nowrap;
}
 
.tag-chip-x {
  cursor:pointer;
  opacity:.7;
  font-size:.85rem;
  line-height:1;
}
 
.tag-chip-x:hover {
  opacity:1;
  color:var(--accent2);
}
 
.tag-real-input {
  border:none;
  background:transparent;
  outline:none;
  color:var(--text);
  font-family:'Hind Siliguri',sans-serif;
  font-size:.88rem;
  min-width:80px;
  flex:1;
}
 
/* Image upload button */
.img-upload-label {
  display:inline-flex;
  align-items:center;
  gap:5px;
  padding:9px 13px;
  background:linear-gradient(135deg,var(--blue),#6c63ff);
  color:#fff;
  border-radius:10px;
  font-family:'Baloo Da 2',cursive;
  font-size:.82rem;
  font-weight:700;
  cursor:pointer;
  white-space:nowrap;
  transition:transform .15s,opacity .15s;
  flex-shrink:0;
}
 
.img-upload-label:hover {
  transform:translateY(-1px);
  opacity:.9;
}
 
/* Image preview in quiz */
.q-image-wrap {
  margin-bottom:10px;
  border-radius:11px;
  overflow:hidden;
  border:1px solid var(--border);
  max-height:200px;
}
 
.q-image-wrap img {
  width:100%;
  height:auto;
  max-height:200px;
  object-fit:contain;
  background:#0d0f1a;
}
 
.img-err{display:none;}
 
/* Explanation box (in review) */
.explanation-box {
  background:rgba(67,233,123,.07);
  border:1px solid rgba(67,233,123,.25);
  border-radius:9px;
  padding:9px 13px;
  margin-top:8px;
  font-size:.84rem;
  color:var(--green);
  line-height:1.6;
}
 
.explanation-box strong {
  display:block;
  margin-bottom:3px;
  font-size:.78rem;
  letter-spacing:.5px;
  text-transform:uppercase;
}
 
/* Marks badge variants */
.mark-badge-custom {
  background:rgba(251,146,60,.12);
  border:1px solid rgba(251,146,60,.35);
  color:var(--orange);
  font-size:.75rem;
  font-weight:700;
  padding:2px 9px;
  border-radius:20px;
}
 
/* Toggle switch */
.toggle-row {
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:9px 0;
  border-bottom:1px solid var(--border);
}
 
.toggle-row:last-child{border-bottom:none;}
.toggle-label {
  font-size:.88rem;
  color:var(--text);
}
 
.toggle-sub {
  font-size:.74rem;
  color:var(--muted);
  margin-top:2px;
}
 
.switch {
  position:relative;
  width:44px;
  height:24px;
  flex-shrink:0;
}
 
.switch input {
  opacity:0;
  width:0;
  height:0;
}
 
.slider {
  position:absolute;
  cursor:pointer;
  inset:0;
  background:var(--border);
  border-radius:24px;
  transition:.3s;
}
 
.slider:before {
  content:'';
  position:absolute;
  height:18px;
  width:18px;
  left:3px;
  bottom:3px;
  background:#fff;
  border-radius:50%;
  transition:.3s;
}
 
input:checked+.slider{background:var(--accent);}
input:checked+.slider:before{transform:translateX(20px);}
 
/* Bulk import format helper */
.format-hint {
  background:var(--card2);
  border:1px solid var(--border);
  border-radius:9px;
  padding:10px 13px;
  font-size:.75rem;
  color:var(--muted);
  margin-top:8px;
  font-family:monospace;
  white-space:pre-wrap;
  line-height:1.6;
}
 
/* Export button */
.btn-export {
  background:linear-gradient(135deg,var(--purple),#6c63ff);
  color:#fff;
}
 
/* ── WORD LINK EDITOR ── */
.wl-editor-wrap{position:relative;}
.wl-preview {
  min-height:72px;
  background:var(--card2);
  border:1.5px solid var(--border);
  border-radius:11px;
  padding:10px 14px;
  color:var(--text);
  font-family:'Hind Siliguri',sans-serif;
  font-size:.93rem;
  line-height:1.6;
  cursor:text;
  white-space:pre-wrap;
  word-break:break-word;
  outline:none;
  transition:border-color .2s;
}
 
.wl-preview:focus-within{border-color:var(--accent);}
.wl-preview[contenteditable][placeholder]:empty:before {
  content:attr(placeholder);
  color:var(--muted);
  pointer-events:none;
}
 
.wl-preview[contenteditable]:focus {
  border-color:var(--accent);
  outline:none;
}
 
.wl-linked {
  color:var(--blue);
  text-decoration:underline dotted;
  cursor:pointer;
  border-radius:3px;
  padding:0 1px;
  transition:background .15s;
  position:relative;
}
 
.wl-linked:hover{background:rgba(56,178,245,.15);}
.wl-linked-badge {
  font-size:.6rem;
  vertical-align:super;
  margin-left:1px;
  opacity:.7;
}
 
/* word-link toolbar (floating) */
.wl-toolbar {
  position:fixed;
  z-index:9999;
  background:var(--card);
  border:1.5px solid var(--blue);
  border-radius:12px;
  padding:10px 13px;
  box-shadow:0 8px 32px rgba(0,0,0,.6);
  min-width:280px;
  display:none;
  flex-direction:column;
  gap:8px;
  animation:fadeIn .15s ease;
}
 
.wl-toolbar.open{display:flex;}
.wl-toolbar-title {
  font-size:.75rem;
  color:var(--blue);
  font-weight:700;
  letter-spacing:.5px;
  text-transform:uppercase;
}
 
.wl-selected-word {
  font-size:.82rem;
  background:rgba(56,178,245,.12);
  border:1px solid rgba(56,178,245,.3);
  border-radius:7px;
  padding:3px 10px;
  color:var(--text);
  font-weight:600;
  margin-bottom:2px;
}
 
.wl-url-input {
  width:100%;
  background:var(--card2);
  border:1.5px solid var(--border);
  border-radius:9px;
  padding:7px 11px;
  color:var(--text);
  font-family:'Hind Siliguri',sans-serif;
  font-size:.85rem;
  outline:none;
  transition:border-color .2s;
}
 
.wl-url-input:focus{border-color:var(--blue);}
.wl-url-input::placeholder{color:var(--muted);}
.wl-toolbar-actions {
  display:flex;
  gap:7px;
}
 
.wl-btn {
  flex:1;
  padding:6px 10px;
  border:none;
  border-radius:8px;
  font-family:'Baloo Da 2',cursive;
  font-size:.82rem;
  font-weight:700;
  cursor:pointer;
  transition:all .15s;
}
 
.wl-btn:hover{opacity:.88;}
.wl-btn-add {
  background:linear-gradient(135deg,var(--blue),#6c63ff);
  color:#fff;
}
 
.wl-btn-remove {
  background:rgba(255,107,107,.15);
  border:1px solid rgba(255,107,107,.4);
  color:var(--accent2);
}
 
.wl-btn-cancel {
  background:var(--card2);
  border:1px solid var(--border);
  color:var(--muted);
}
 
.wl-hint {
  font-size:.72rem;
  color:var(--muted);
  margin-top:2px;
}
 
/* linked word in quiz question */
.q-linked-word {
  color:var(--blue);
  text-decoration:underline dotted;
  cursor:pointer;
  border-radius:3px;
  padding:0 2px;
  transition:background .15s;
}
 
.q-linked-word:hover {
  background:rgba(56,178,245,.18);
  text-decoration:underline;
}
 
/* linked word list in q-item admin */
.wl-list {
  display:flex;
  flex-direction:column;
  gap:4px;
  margin-top:6px;
}
 
.wl-item {
  display:flex;
  align-items:center;
  gap:6px;
  background:rgba(56,178,245,.07);
  border:1px solid rgba(56,178,245,.25);
  border-radius:8px;
  padding:4px 9px;
  font-size:.76rem;
}
 
.wl-item-word {
  color:var(--blue);
  font-weight:600;
}
 
.wl-item-url {
  color:var(--muted);
  flex:1;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
  max-width:160px;
}
 
.wl-item-del {
  cursor:pointer;
  color:var(--accent2);
  font-size:.9rem;
  flex-shrink:0;
  opacity:.8;
}
 
.wl-item-del:hover{opacity:1;}
 
/* Stats extra */
.stats-row-4 {
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:9px;
  margin-bottom:16px;
}
 
@media(max-width:560px){.stats-row-4{grid-template-columns:repeat(2,1fr);}}
 
/* RANK CARD (result screen) */
.my-rank-card {
  background:linear-gradient(135deg,rgba(247,201,72,.12),rgba(255,159,67,.08));
  border:2px solid rgba(247,201,72,.4);
  border-radius:16px;
  padding:18px 22px;
  text-align:center;
  margin-bottom:14px;
}
 
.my-rank-num {
  font-family:'Baloo Da 2',cursive;
  font-size:3.2rem;
  font-weight:800;
  background:linear-gradient(135deg,var(--accent),#ff9f43);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  line-height:1;
}
 
.my-rank-label {
  color:var(--muted);
  font-size:.82rem;
  margin-top:4px;
}
 
.my-rank-out-of {
  font-size:.9rem;
  color:var(--text);
  margin-top:2px;
  font-weight:500;
}
 
/* PUBLIC LEADERBOARD */
.lb-wrap {
  width:100%;
  max-width:660px;
}
 
.lb-header {
  text-align:center;
  margin-bottom:20px;
}
 
.lb-title {
  font-family:'Baloo Da 2',cursive;
  font-size:1.8rem;
  font-weight:800;
  background:linear-gradient(135deg,var(--accent),#ff9f43);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}
 
.lb-filters {
  display:flex;
  gap:8px;
  margin-bottom:14px;
  flex-wrap:wrap;
  justify-content:center;
}
 
.lb-filters select {
  background:var(--card2);
  border:1.5px solid var(--border);
  border-radius:10px;
  padding:8px 13px;
  color:var(--text);
  font-family:'Hind Siliguri',sans-serif;
  font-size:.88rem;
  outline:none;
  cursor:pointer;
}
 
.lb-filters select:focus{border-color:var(--accent);}
.lb-table {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
}
 
.lb-head {
  display:grid;
  grid-template-columns:52px 1fr 90px 100px 80px;
  padding:11px 16px;
  background:var(--card2);
  border-bottom:1px solid var(--border);
  font-size:.75rem;
  color:var(--muted);
  font-weight:600;
  text-transform:uppercase;
  letter-spacing:.4px;
}
 
.lb-row {
  display:grid;
  grid-template-columns:52px 1fr 90px 100px 80px;
  padding:12px 16px;
  border-bottom:1px solid var(--border);
  align-items:center;
  transition:background .15s;
}
 
.lb-row:last-child{border-bottom:none;}
.lb-row:hover{background:rgba(247,201,72,.04);}
.lb-row.my-row {
  background:rgba(247,201,72,.08);
  border-left:3px solid var(--accent);
}
 
.lb-rank {
  font-family:'Baloo Da 2',cursive;
  font-weight:800;
  font-size:1.1rem;
  text-align:center;
}
 
.lb-rank.r1{color:var(--accent);}
.lb-rank.r2{color:#bdc3d4;}
.lb-rank.r3{color:#cd7f32;}
.lb-rank.rn {
  color:var(--muted);
  font-size:.9rem;
}
 
.lb-name {
  font-weight:600;
  font-size:.9rem;
}
 
.lb-name.me{color:var(--accent);}
.lb-score {
  font-family:'Baloo Da 2',cursive;
  font-weight:700;
  font-size:.95rem;
  color:var(--green);
}
 
.lb-pct {
  font-size:.82rem;
  color:var(--muted);
  text-align:center;
}
 
.lb-time {
  font-size:.8rem;
  color:var(--blue);
  text-align:right;
}
 
.lb-you-badge {
  display:inline-block;
  background:rgba(247,201,72,.15);
  border:1px solid rgba(247,201,72,.4);
  color:var(--accent);
  font-size:.65rem;
  font-weight:700;
  padding:1px 6px;
  border-radius:20px;
  margin-left:4px;
  vertical-align:middle;
}
 
@media(max-width:560px){
.card {
  padding:16px 13px;
  }.stats-row{grid-template-columns:1fr 1fr;
}
.tbl-head,.tbl-row {
  grid-template-columns:30px 1fr 72px 68px 90px 64px;
  padding:8px 10px;
  font-size:.7rem;
}
 
.logo-title {
  font-size:1.8rem;
  }.big-timer-display{font-size:3rem;
}
.sel-grid{grid-template-columns:repeat(2,1fr);}
.tab-btn {
  font-size:.76rem;
  padding:7px 3px;
  }.modal{padding:15px;
}
.result-marks-row{gap:8px;}
.lb-head,.lb-row {
  grid-template-columns:44px 1fr 80px 88px 70px;
  padding:9px 12px;
  font-size:.74rem;
}
 
}
 
.code-box {
  width:44px;
  height:54px;
  text-align:center;
  font-family:'Baloo Da 2',cursive;
  font-size:1.6rem;
  font-weight:800;
  background:var(--card2);
  border:2px solid var(--border);
  border-radius:10px;
  color:var(--accent);
  outline:none;
  transition:border-color .2s,box-shadow .2s;
}
 
.code-box:focus {
  border-color:var(--accent);
  box-shadow:0 0 0 3px rgba(247,201,72,.2);
}
 
@media(max-width:400px) {
